// fw3 data model — SQL Server, multi-tenant.
// Money/qty are DECIMAL (never float). IDs are app-generated UUIDs stored as
// CHAR(36) (NVarChar default for String would be too wide to index as a PK).
// CHECK constraints + the valuation view are added in the migration SQL by hand
// (Prisma can't express them declaratively).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

// Prisma 7: connection URL lives in prisma.config.ts (datasource.url), not here.
datasource db {
  provider = "sqlserver"
}

model Tenant {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @db.NVarChar(200)
  slug      String   @unique @db.NVarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  roles          Role[]
  inventoryItems InventoryItem[]
  auditLogs      AuditLog[]
  qbConnections  QbConnection[]
  formulas       Formula[]
  inventoryTxns  InventoryTxn[]
  itemStocks     ItemStock[]
  vendors        Vendor[]
  purchaseOrders PurchaseOrder[]
  customers           Customer[]
  salesOrders         SalesOrder[]
  productionWorkOrders ProductionWorkOrder[]
  itemQualitySpecs    ItemQualitySpec[]
  receivedLots        ReceivedLot[]
  locations           Location[]
  itemStockLocations  ItemStockLocation[]
  locationMoves       LocationMove[]
  compounderPours     CompounderPour[]
  cycleCounts         CycleCount[]
  cycleCountLines     CycleCountLine[]
  scrapRecords        ScrapRecord[]
  vendorReturns       VendorReturn[]
}

model User {
  id          String   @id @default(uuid()) @db.Char(36)
  tenantId    String   @db.Char(36)
  idpSub      String   @db.NVarChar(255) // OIDC subject (Entra)
  email       String   @db.NVarChar(320)
  displayName String   @db.NVarChar(200)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userRoles      UserRole[]
  auditLogs      AuditLog[]
  compounderPours CompounderPour[]
  createdCycleCounts   CycleCount[] @relation("CycleCountCreatedBy")
  completedCycleCounts CycleCount[] @relation("CycleCountCompletedBy")
  scrapRecords         ScrapRecord[]
  vendorReturns        VendorReturn[]

  @@unique([tenantId, idpSub])
  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id        String   @id @default(uuid()) @db.Char(36)
  tenantId  String   @db.Char(36)
  name      String   @db.NVarChar(100)
  createdAt DateTime @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// Global catalogue — permissions are app constants, not tenant-scoped.
model Permission {
  id  String @id @default(uuid()) @db.Char(36)
  key String @unique @db.NVarChar(100) // e.g. "inventory:read"

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String @db.Char(36)
  permissionId String @db.Char(36)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId String @db.Char(36)
  roleId String @db.Char(36)

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  role Role @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([userId, roleId])
  @@index([roleId])
}

model InventoryItem {
  id             String    @id @default(uuid()) @db.Char(36)
  tenantId       String    @db.Char(36)
  sku            String    @db.NVarChar(64)
  name           String    @db.NVarChar(200)
  description    String?   @db.NVarChar(2000)
  // RAW_MATERIAL | FINISHED_GOOD — enforced by a CHECK constraint (SQL Server
  // has no native enum; see migration). Most inventory is raw materials.
  itemType       String    @default("RAW_MATERIAL") @db.NVarChar(20)
  // LIQUID | SOLID — selects the QC acceptance-test suite (crystals = SOLID).
  physicalForm   String    @default("LIQUID") @db.NVarChar(10)
  // LB | KG — also CHECK-constrained. Fragrance is stored by weight, mostly lbs.
  unitOfMeasure  String    @default("LB") @db.NVarChar(16)
  salesPrice     Decimal   @default(0) @db.Decimal(19, 4)
  active         Boolean   @default(true)
  // ---- Item master / QuickBooks attributes (NO inventory position here;
  // quantity + moving-average cost live in ItemStock / the ledger) ----
  qbItemType          String    @default("INVENTORY") @db.NVarChar(20) // INVENTORY | NON_INVENTORY | SERVICE
  standardCost        Decimal   @default(0) @db.Decimal(19, 4) // item-record purchase/standard cost
  purchaseDescription String?   @db.NVarChar(2000)
  incomeAccount       String?   @db.NVarChar(159) // QB account full names
  cogsAccount         String?   @db.NVarChar(159)
  assetAccount        String?   @db.NVarChar(159)
  // QuickBooks linkage from the QBWC round-trip (per tenant).
  qbListId       String?   @db.NVarChar(64)
  qbEditSequence String?   @db.NVarChar(64)
  qbSyncedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  // Formulas where this item is the finished good, and formula lines that use it
  // as a raw material.
  finishedGoodFormulas    Formula[]           @relation("FinishedGoodFormulas")
  rawMaterialFormulaLines FormulaLine[]       @relation("RawMaterialFormulaLines")
  txns                    InventoryTxn[]
  stocks                  ItemStock[]
  purchaseOrderLines      PurchaseOrderLine[]   @relation("ItemPurchaseOrderLines")
  salesOrderLines         SalesOrderLine[]      @relation("ItemSalesOrderLines")
  targetWorkOrders        ProductionWorkOrder[]     @relation("TargetProductionRuns")
  componentWorkOrderLines ProductionWorkOrderLine[] @relation("ComponentProductionRunLines")
  qualitySpecs            ItemQualitySpec[]
  receivedLots            ReceivedLot[]
  stockLocations          ItemStockLocation[]
  locationMoves           LocationMove[]
  componentPours          CompounderPour[]          @relation("ComponentPours")
  cycleCountLines         CycleCountLine[]
  scrapRecords            ScrapRecord[]
  vendorReturns           VendorReturn[]

  @@unique([tenantId, sku])
  @@index([tenantId])
}

// Per-item QC acceptance criteria for a test type. NUMERIC tests (specific
// gravity, refractive index, Gardner color, melting point) use min/max; JUDGMENT
// tests (odor, appearance) are passed/failed by the analyst, optionally against
// an expectedValue reference description.
model ItemQualitySpec {
  id            String   @id @default(uuid()) @db.Char(36)
  tenantId      String   @db.Char(36)
  itemId        String   @db.Char(36)
  testType      String   @db.NVarChar(30) // SPECIFIC_GRAVITY | REFRACTIVE_INDEX | GARDNER_COLOR | ODOR | APPEARANCE | MELTING_POINT
  minValue      Decimal? @db.Decimal(18, 6)
  maxValue      Decimal? @db.Decimal(18, 6)
  expectedValue String?  @db.NVarChar(200)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([itemId, testType])
  @@index([tenantId])
}

// A lot of material, quarantined/produced pending QC. Origin RECEIPT (vendor) or
// PRODUCTION (work order); vendor/PO/WO are snapshotted by name. (Table kept as
// ReceivedLot for history; the app concept is a generic "Lot".)
model ReceivedLot {
  id                  String    @id @default(uuid()) @db.Char(36)
  tenantId            String    @db.Char(36)
  origin              String    @default("RECEIPT") @db.NVarChar(20) // RECEIPT | PRODUCTION
  itemId              String    @db.Char(36)
  purchaseOrderId     String?   @db.Char(36)
  purchaseOrderLineId String?   @db.Char(36)
  purchaseOrderNumber String?   @db.NVarChar(50)
  vendorName          String?   @db.NVarChar(200)
  sourceWorkOrderId   String?   @db.Char(36)
  workOrderNumber     String?   @db.NVarChar(50)
  supplierLotNumber   String    @db.NVarChar(80) // lot number (supplier's, or WO-derived)
  locationId          String?   @db.Char(36) // where it was quarantined (drives QC-approve routing)
  quantity            Decimal   @db.Decimal(18, 4)
  packedQty           Decimal   @default(0) @db.Decimal(18, 4) // packed off so far (production lots)
  returnedQty         Decimal   @default(0) @db.Decimal(18, 4) // returned to vendor (QC-fail returns)
  unitCost            Decimal   @db.Decimal(19, 4)
  qcStatus            String    @default("PENDING") @db.NVarChar(20) // PENDING | APPROVED | REJECTED | RETURNED
  rejectionReason     String?   @db.NVarChar(500)
  receivedAt          DateTime  @default(now())
  reviewedAt          DateTime?
  reviewedById        String?   @db.Char(36)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item     InventoryItem       @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  location Location?           @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  results  QualityTestResult[]
  vendorReturns VendorReturn[]

  @@index([tenantId, qcStatus])
  @@index([itemId])
}

model QualityTestResult {
  id            String   @id @default(uuid()) @db.Char(36)
  receivedLotId String   @db.Char(36)
  testType      String   @db.NVarChar(30)
  measuredValue String?  @db.NVarChar(200)
  passed        Boolean?
  notes         String?  @db.NVarChar(500)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  receivedLot ReceivedLot @relation(fields: [receivedLotId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([receivedLotId, testType])
  @@index([receivedLotId])
}

// Per-(item, state) position. State separates LOT-traceable inventory (INV) from
// work-in-progress (WIP: RM in refill cans, FG in the vat before packing). INV is
// mirrored onto InventoryItem.quantityOnHand/unitCost for existing reads; this
// table is the authoritative position for every state.
model ItemStock {
  id        String   @id @default(uuid()) @db.Char(36)
  tenantId  String   @db.Char(36)
  itemId    String   @db.Char(36)
  status    String   @map("state") @db.NVarChar(10) // INV | WIP
  quantity  Decimal  @default(0) @db.Decimal(18, 4)
  avgCost   Decimal  @default(0) @db.Decimal(19, 4)
  updatedAt DateTime @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([itemId, status])
  @@index([tenantId, status])
}

// A physical inventory location, as a tree of typed levels:
//   BUILDING (bbb) -> AISLE (a) -> RACK (first n; bin/sub-bin reserved)
// plus AREA nodes (e.g. receiving) hanging off a building. `code` is the full
// composed "bbb-a-nnn" address; `segment` is this node's own part. Stock sits at
// leaves (RACK/AREA). Per building, at most one isDefault and one isReceiving
// (filtered unique indexes in the migration). buildingId is the building
// ancestor (its own id for a building node) for fast per-building scoping.
model Location {
  id          String     @id @default(uuid()) @db.Char(36)
  tenantId    String     @db.Char(36)
  kind        String     @default("AREA") @db.NVarChar(10) // BUILDING | AISLE | RACK | AREA
  parentId    String?    @db.Char(36)
  buildingId  String?    @db.Char(36)
  name        String     @db.NVarChar(100)
  segment     String     @default("") @db.NVarChar(20) // own code part: "075" | "A" | "100" | "RECV"
  code        String     @default("") @db.NVarChar(40) // full composed code, e.g. "075-A-100"
  side        String?    @db.NVarChar(8) // LEFT | RIGHT (racks)
  isDefault   Boolean    @default(false)
  isReceiving Boolean    @default(false)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parent       Location?           @relation("LocationChildren", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     Location[]          @relation("LocationChildren")
  building     Location?           @relation("LocationBuilding", fields: [buildingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  inBuilding   Location[]          @relation("LocationBuilding")
  stocks       ItemStockLocation[]
  movesFrom    LocationMove[]      @relation("MoveFromLocation")
  movesTo      LocationMove[]      @relation("MoveToLocation")
  receivedLots ReceivedLot[]
  cycleCountScopes CycleCount[]
  cycleCountLines  CycleCountLine[]
  scrapRecords     ScrapRecord[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([parentId])
  @@index([buildingId])
}

// Quantity of an item, in one stock status, sitting at one location. Cost is
// item-level (kept on ItemStock), so this is a pure quantity breakdown: the sum
// over locations for a (item, status) equals that ItemStock row's quantity.
// Only located statuses (INV, QUARANTINE) get rows here; WIP is not located.
model ItemStockLocation {
  id         String   @id @default(uuid()) @db.Char(36)
  tenantId   String   @db.Char(36)
  itemId     String   @db.Char(36)
  status     String   @map("state") @db.NVarChar(10) // INV | QUARANTINE
  locationId String   @db.Char(36)
  quantity   Decimal  @default(0) @db.Decimal(18, 4)
  updatedAt  DateTime @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item     InventoryItem @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  location Location      @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([itemId, status, locationId])
  @@index([tenantId])
  @@index([locationId])
}

// Append-only ledger of physical moves between locations. Null from/to allows
// recording placements/removals driven by other flows if ever needed; the
// move-stock operation always sets both.
model LocationMove {
  id             String   @id @default(uuid()) @db.Char(36)
  tenantId       String   @db.Char(36)
  itemId         String   @db.Char(36)
  status         String   @map("state") @db.NVarChar(10) // INV | QUARANTINE
  fromLocationId String?  @db.Char(36)
  toLocationId   String?  @db.Char(36)
  quantity       Decimal  @db.Decimal(18, 4)
  note           String?  @db.NVarChar(500)
  actorId        String?  @db.Char(36)
  occurredAt     DateTime @default(now())

  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item         InventoryItem @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fromLocation Location? @relation("MoveFromLocation", fields: [fromLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  toLocation   Location? @relation("MoveToLocation", fields: [toLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, itemId, occurredAt])
}

// Append-only stock ledger. Every quantity change is one signed line; an item's
// position is the running balance carried on the latest line (and mirrored on
// the InventoryItem row). Weighted-average cost: balanceAvgCost is re-averaged
// on inbound and unchanged on outbound.
model InventoryTxn {
  id             String   @id @default(uuid()) @db.Char(36)
  tenantId       String   @db.Char(36)
  itemId         String   @db.Char(36)
  type           String   @db.NVarChar(30) // RECEIPT | CONSUME | PRODUCTION_OUTPUT | SHIPMENT | ADJUSTMENT | TRANSFER
  status         String   @default("INV") @map("state") @db.NVarChar(10) // INV | WIP — which bucket this line moved
  quantity       Decimal  @db.Decimal(18, 4) // signed: + inbound, - outbound
  unitCost       Decimal  @db.Decimal(19, 4) // cost per unit applied by this line
  value          Decimal  @db.Decimal(38, 4) // signed = quantity * unitCost
  balanceQty     Decimal  @db.Decimal(38, 4) // on-hand quantity after this line
  balanceAvgCost Decimal  @db.Decimal(19, 4) // moving average cost after this line
  docType        String?  @db.NVarChar(30) // PURCHASE_ORDER | PRODUCTION_RUN | SALES_ORDER | ADJUSTMENT
  docId          String?  @db.Char(36)
  note           String?  @db.NVarChar(500)
  occurredAt     DateTime @default(now())

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, itemId, occurredAt])
  @@index([tenantId, docType, docId])
}

model Vendor {
  id        String   @id @default(uuid()) @db.Char(36)
  tenantId  String   @db.Char(36)
  name      String   @db.NVarChar(200)
  code      String?  @db.NVarChar(50)
  email     String?  @db.NVarChar(320)
  phone     String?  @db.NVarChar(50)
  website   String?  @db.NVarChar(200)
  taxId     String?  @db.NVarChar(50)
  paymentTerms String? @db.NVarChar(20) // DUE_ON_RECEIPT | NET_15 | NET_30 | ... (CHECK in migration)
  notes     String?  @db.NVarChar(2000)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchaseOrders PurchaseOrder[]
  addresses      VendorAddress[]
  contacts       VendorContact[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// Addresses for a vendor (billing / shipping / remit-to / other). Scoped via the
// parent vendor (like PO lines), so no tenantId of its own.
model VendorAddress {
  id         String  @id @default(uuid()) @db.Char(36)
  vendorId   String  @db.Char(36)
  kind       String  @default("OTHER") @db.NVarChar(20) // BILLING | SHIPPING | REMIT_TO | OTHER
  label      String? @db.NVarChar(100)
  line1      String  @db.NVarChar(200)
  line2      String? @db.NVarChar(200)
  city       String? @db.NVarChar(100)
  region     String? @db.NVarChar(100)
  postalCode String? @db.NVarChar(20)
  country    String? @db.NVarChar(100)
  isPrimary  Boolean @default(false)
  sortOrder  Int     @default(0)

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([vendorId])
}

model VendorContact {
  id        String  @id @default(uuid()) @db.Char(36)
  vendorId  String  @db.Char(36)
  name      String  @db.NVarChar(200)
  title     String? @db.NVarChar(100)
  email     String? @db.NVarChar(320)
  phone     String? @db.NVarChar(50)
  isPrimary Boolean @default(false)
  notes     String? @db.NVarChar(500)
  sortOrder Int     @default(0)

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([vendorId])
}

model PurchaseOrder {
  id        String   @id @default(uuid()) @db.Char(36)
  tenantId  String   @db.Char(36)
  vendorId  String   @db.Char(36)
  poNumber  String   @db.NVarChar(50)
  status    String   @default("OPEN") @db.NVarChar(20) // OPEN | PARTIAL | RECEIVED | CANCELLED
  orderDate DateTime @default(now())
  notes     String?  @db.NVarChar(2000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant              @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendor Vendor              @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lines  PurchaseOrderLine[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@index([tenantId, vendorId])
}

model PurchaseOrderLine {
  id               String  @id @default(uuid()) @db.Char(36)
  purchaseOrderId  String  @db.Char(36)
  itemId           String  @db.Char(36)
  quantityOrdered  Decimal @db.Decimal(18, 4)
  unitCost         Decimal @db.Decimal(19, 4)
  quantityReceived Decimal @default(0) @db.Decimal(18, 4)
  sortOrder        Int     @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item          InventoryItem @relation("ItemPurchaseOrderLines", fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([purchaseOrderId])
  @@index([itemId])
}

model Customer {
  id        String   @id @default(uuid()) @db.Char(36)
  tenantId  String   @db.Char(36)
  name      String   @db.NVarChar(200)
  code      String?  @db.NVarChar(50)
  email     String?  @db.NVarChar(320)
  phone     String?  @db.NVarChar(50)
  website   String?  @db.NVarChar(200)
  taxId     String?  @db.NVarChar(50)
  paymentTerms String? @db.NVarChar(20) // DUE_ON_RECEIPT | NET_15 | ... (CHECK in migration)
  rating    String?  @db.NVarChar(1) // A | B | C | D — sales buy-volume rating (CHECK in migration)
  notes     String?  @db.NVarChar(2000)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  salesOrders SalesOrder[]
  addresses   CustomerAddress[]
  contacts    CustomerContact[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// Addresses for a customer (billing / shipping / other). Scoped via the parent.
model CustomerAddress {
  id         String  @id @default(uuid()) @db.Char(36)
  customerId String  @db.Char(36)
  kind       String  @default("OTHER") @db.NVarChar(20) // BILLING | SHIPPING | REMIT_TO | OTHER
  label      String? @db.NVarChar(100)
  line1      String  @db.NVarChar(200)
  line2      String? @db.NVarChar(200)
  city       String? @db.NVarChar(100)
  region     String? @db.NVarChar(100)
  postalCode String? @db.NVarChar(20)
  country    String? @db.NVarChar(100)
  isPrimary  Boolean @default(false)
  sortOrder  Int     @default(0)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([customerId])
}

model CustomerContact {
  id         String  @id @default(uuid()) @db.Char(36)
  customerId String  @db.Char(36)
  name       String  @db.NVarChar(200)
  title      String? @db.NVarChar(100)
  email      String? @db.NVarChar(320)
  phone      String? @db.NVarChar(50)
  isPrimary  Boolean @default(false)
  notes      String? @db.NVarChar(500)
  sortOrder  Int     @default(0)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([customerId])
}

model SalesOrder {
  id         String   @id @default(uuid()) @db.Char(36)
  tenantId   String   @db.Char(36)
  customerId String   @db.Char(36)
  soNumber   String   @db.NVarChar(50)
  status     String   @default("OPEN") @db.NVarChar(20) // OPEN | PARTIAL | SHIPPED | CANCELLED
  orderDate  DateTime @default(now())
  notes      String?  @db.NVarChar(2000)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer Customer         @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lines    SalesOrderLine[]

  @@unique([tenantId, soNumber])
  @@index([tenantId])
  @@index([tenantId, customerId])
}

model SalesOrderLine {
  id              String  @id @default(uuid()) @db.Char(36)
  salesOrderId    String  @db.Char(36)
  itemId          String  @db.Char(36)
  quantityOrdered Decimal @db.Decimal(18, 4)
  unitPrice       Decimal @db.Decimal(19, 4)
  quantityShipped Decimal @default(0) @db.Decimal(18, 4)
  sortOrder       Int     @default(0)

  salesOrder SalesOrder    @relation(fields: [salesOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item       InventoryItem @relation("ItemSalesOrderLines", fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([salesOrderId])
  @@index([itemId])
}

// A production run makes a target (finished good or base) from a formula.
// Flow: PLANNED -> (stage components INV->WIP) STAGED -> (consume WIP, output to
// FG_WIP) COMPLETED. Pack-off (FG_WIP->FG_INV) is a separate stock operation.
// "Production work order" in the UI/API. Physical tables keep their original
// names via @@map/@map so this rename needs no data migration.
model ProductionWorkOrder {
  id              String   @id @default(uuid()) @db.Char(36)
  tenantId        String   @db.Char(36)
  workOrderNumber String   @map("runNumber") @db.NVarChar(50)
  targetItemId    String   @db.Char(36)
  formulaId       String   @db.Char(36)
  batchSize       Decimal  @db.Decimal(18, 4) // total batch weight in batchUnit
  batchUnit       String   @db.NVarChar(16) // LB | KG (formula scaling unit)
  outputQty       Decimal  @db.Decimal(18, 4) // produced qty of target (target's UoM)
  status          String   @default("PLANNED") @db.NVarChar(20) // PLANNED | STAGED | IN_PROGRESS | ON_HOLD | COMPLETED | CANCELLED
  notes           String?  @db.NVarChar(2000)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant                    @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  target  InventoryItem             @relation("TargetProductionRuns", fields: [targetItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  formula Formula                   @relation(fields: [formulaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lines   ProductionWorkOrderLine[]
  pours   CompounderPour[]

  @@unique([tenantId, workOrderNumber])
  @@index([tenantId])
  @@map("ProductionRun")
}

model ProductionWorkOrderLine {
  id                    String  @id @default(uuid()) @db.Char(36)
  productionWorkOrderId String  @map("productionRunId") @db.Char(36)
  componentId           String  @db.Char(36)
  requiredQty           Decimal @db.Decimal(18, 4) // in the component's stocking unit
  stagedQty             Decimal @default(0) @db.Decimal(18, 4)
  consumedQty           Decimal @default(0) @db.Decimal(18, 4)
  sortOrder             Int     @default(0)

  workOrder ProductionWorkOrder @relation(fields: [productionWorkOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  component InventoryItem       @relation("ComponentProductionRunLines", fields: [componentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pours     CompounderPour[]

  @@index([productionWorkOrderId])
  @@index([componentId])
  @@map("ProductionRunLine")
}

// One pour reported by the compounder dosing tool: an operator dosed `quantity`
// (canonical pounds) of `component` into a work order's batch. Append-only; each
// pour also posts a CONSUME transaction from WIP (pours drive consumption).
model CompounderPour {
  id                    String   @id @default(uuid()) @db.Char(36)
  tenantId              String   @db.Char(36)
  productionWorkOrderId String   @map("productionRunId") @db.Char(36)
  workOrderLineId       String   @map("productionRunLineId") @db.Char(36)
  componentId           String   @db.Char(36)
  quantity              Decimal  @db.Decimal(18, 4)
  operatorId            String   @db.Char(36)
  note                  String?  @db.NVarChar(500)
  occurredAt            DateTime @default(now())

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  workOrder ProductionWorkOrder     @relation(fields: [productionWorkOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  line      ProductionWorkOrderLine @relation(fields: [workOrderLineId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  component InventoryItem           @relation("ComponentPours", fields: [componentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  operator  User                    @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, productionWorkOrderId])
  @@index([operatorId])
}

// A fragrance formula: finished good = raw materials by percentage of weight.
model Formula {
  id             String   @id @default(uuid()) @db.Char(36)
  tenantId       String   @db.Char(36)
  finishedGoodId String   @db.Char(36)
  name           String   @db.NVarChar(200)
  version        Int      @default(1)
  notes          String?  @db.NVarChar(2000)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  finishedGood   InventoryItem   @relation("FinishedGoodFormulas", fields: [finishedGoodId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lines          FormulaLine[]
  productionWorkOrders ProductionWorkOrder[]

  @@unique([tenantId, finishedGoodId, version])
  @@index([tenantId])
}

model FormulaLine {
  id            String  @id @default(uuid()) @db.Char(36)
  formulaId     String  @db.Char(36)
  rawMaterialId String  @db.Char(36)
  // Percent of total weight; 0 < percentage <= 100 (CHECK in migration). Lines
  // for a formula must sum to 100 (enforced in the service).
  percentage    Decimal @db.Decimal(7, 4)
  sortOrder     Int     @default(0)

  formula     Formula       @relation(fields: [formulaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rawMaterial InventoryItem @relation("RawMaterialFormulaLines", fields: [rawMaterialId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([formulaId, rawMaterialId])
  @@index([formulaId])
  @@index([rawMaterialId])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Char(36)
  tenantId   String   @db.Char(36)
  actorId    String?  @db.Char(36) // null for system/QBWC actions
  entityType String   @db.NVarChar(100)
  entityId   String   @db.NVarChar(64)
  action     String   @db.NVarChar(50) // CREATE | UPDATE | DELETE | SYNC
  before     String?  @db.NVarChar(Max) // JSON snapshot
  after      String?  @db.NVarChar(Max) // JSON snapshot
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  actor  User?  @relation(fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
}

// Per-tenant QuickBooks Web Connector connection.
model QbConnection {
  id               String    @id @default(uuid()) @db.Char(36)
  tenantId         String    @db.Char(36)
  name             String    @db.NVarChar(200)
  qbwcUsername     String    @unique @db.NVarChar(100) // login QBWC authenticates with
  qbwcPasswordHash String    @db.NVarChar(255) // argon2 hash
  companyFile      String?   @db.NVarChar(500)
  lastSyncAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sessions QbwcSession[]

  @@index([tenantId])
}

// One in-flight QBWC sync session (ticket lifecycle).
model QbwcSession {
  id           String   @id @default(uuid()) @db.Char(36)
  connectionId String   @db.Char(36)
  ticket       String   @unique @db.NVarChar(100)
  status       String   @db.NVarChar(50) // OPEN | DONE | ERROR
  lastError    String?  @db.NVarChar(Max)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connection QbConnection @relation(fields: [connectionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([connectionId])
}

// A cycle count: verify physical inventory at a location (or the whole tenant)
// against the system, then post the variances as ADJUSTMENT transactions. Blind
// counts hide the system quantity from the counter until posted.
model CycleCount {
  id              String    @id @default(uuid()) @db.Char(36)
  tenantId        String    @db.Char(36)
  reference       String    @db.NVarChar(50)
  status          String    @default("OPEN") @db.NVarChar(20) // OPEN | COMPLETED | CANCELLED
  blind           Boolean   @default(false)
  scopeLocationId String?   @db.Char(36) // null = whole tenant
  note            String?   @db.NVarChar(500)
  createdById     String    @db.Char(36)
  completedById   String?   @db.Char(36)
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scopeLocation Location?        @relation(fields: [scopeLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy     User             @relation("CycleCountCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  completedBy   User?            @relation("CycleCountCompletedBy", fields: [completedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lines         CycleCountLine[]

  @@unique([tenantId, reference])
  @@index([tenantId, status])
}

// One counted cell: an item, in one located status, at one location. expectedQty
// is the system snapshot at creation; countedQty is what the counter found.
model CycleCountLine {
  id           String   @id @default(uuid()) @db.Char(36)
  tenantId     String   @db.Char(36)
  cycleCountId String   @db.Char(36)
  itemId       String   @db.Char(36)
  status       String   @map("state") @db.NVarChar(10) // INV | QUARANTINE
  locationId   String   @db.Char(36)
  expectedQty  Decimal  @db.Decimal(18, 4)
  countedQty   Decimal? @db.Decimal(18, 4)
  counted      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cycleCount CycleCount    @relation(fields: [cycleCountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item       InventoryItem @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  location   Location      @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([cycleCountId, itemId, status, locationId])
  @@index([cycleCountId])
}

// A write-off: scrap of quantity from a stock stage (INV/WIP/QUARANTINE), with a
// reason. The matching ledger movement is an InventoryTxn of type SCRAP; this row
// adds the structured reason, value (loss), location, and operator for reporting.
model ScrapRecord {
  id         String   @id @default(uuid()) @db.Char(36)
  tenantId   String   @db.Char(36)
  itemId     String   @db.Char(36)
  status     String   @map("state") @db.NVarChar(10) // INV | WIP | QUARANTINE
  locationId String?  @db.Char(36)
  quantity   Decimal  @db.Decimal(18, 4)
  value      Decimal  @db.Decimal(38, 4) // written-off value at average cost
  reason     String   @db.NVarChar(20) // DAMAGED | EXPIRED | CONTAMINATED | SPILL | QC_FAILED | OTHER
  note       String?  @db.NVarChar(500)
  operatorId String   @db.Char(36)
  occurredAt DateTime @default(now())

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item     InventoryItem @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  location Location?     @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  operator User          @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, itemId, occurredAt])
  @@index([tenantId, reason])
}

// A return-to-vendor of QC-failed raw material. Removes quantity from quarantine
// (an InventoryTxn of type RETURN) — a recoverable vendor debit, not a loss.
// vendorName / purchaseOrderNumber are snapshotted from the lot for reporting.
model VendorReturn {
  id                  String   @id @default(uuid()) @db.Char(36)
  tenantId            String   @db.Char(36)
  receivedLotId       String   @db.Char(36)
  itemId              String   @db.Char(36)
  vendorName          String?  @db.NVarChar(200)
  purchaseOrderNumber String?  @db.NVarChar(50)
  quantity            Decimal  @db.Decimal(18, 4)
  unitCost            Decimal  @db.Decimal(19, 4)
  value               Decimal  @db.Decimal(38, 4) // recoverable amount (qty * unitCost)
  reason              String?  @db.NVarChar(500)
  rmaNumber           String?  @db.NVarChar(50)
  note                String?  @db.NVarChar(500)
  operatorId          String   @db.Char(36)
  occurredAt          DateTime @default(now())

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  receivedLot ReceivedLot   @relation(fields: [receivedLotId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  operator    User          @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenantId, occurredAt])
  @@index([receivedLotId])
}
