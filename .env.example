# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Database (SQL Server, separate instance) ---
# SA password also consumed by compose.yaml for the dev container.
MSSQL_SA_PASSWORD=Dev_Strong_Pass_2024!
# Prisma connection string. encrypt+trustServerCertificate are required for the
# dev container's self-signed cert. The `fw3` database must exist (see db:create).
DATABASE_URL="sqlserver://localhost:1433;database=fw3;user=sa;password=Dev_Strong_Pass_2024!;encrypt=true;trustServerCertificate=true"

# --- Redis (BullMQ jobs + session store) ---
REDIS_URL="redis://localhost:6379"

# --- Dev auth ---
# Enables POST /auth/dev-login (logs in as the seeded dev-admin). Local only.
DEV_AUTH=true

# --- Session ---
# 32+ random bytes. Generate: openssl rand -base64 48
SESSION_SECRET="change-me-openssl-rand-base64-48"

# --- OIDC: Microsoft Entra ID ---
# App registration in Entra; redirect URI must match OIDC_REDIRECT_URI.
OIDC_ISSUER="https://login.microsoftonline.com/<TENANT_ID>/v2.0"
OIDC_CLIENT_ID="<entra-application-client-id>"
OIDC_CLIENT_SECRET="<entra-client-secret>"
OIDC_REDIRECT_URI="http://localhost:3001/auth/callback"

# --- App ---
API_PORT=3001
WEB_ORIGIN="http://localhost:5173"
NODE_ENV=development
